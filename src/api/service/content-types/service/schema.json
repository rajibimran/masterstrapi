{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text"
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "iconImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "benefits": {
      "type": "component",
      "component": "service.simple-line",
      "repeatable": true
    },
    "pricingRows": {
      "type": "component",
      "component": "service.pricing-row",
      "repeatable": true
    },
    "timeline": {
      "type": "component",
      "component": "service.timeline-step",
      "repeatable": true
    },
    "documents": {
      "type": "component",
      "component": "service.document-item",
      "repeatable": true
    },
    "order": {
      "type": "integer"
    },
    "seo": {
      "type": "component",
      "component": "seo.entry",
      "repeatable": false
    }
  }
}
