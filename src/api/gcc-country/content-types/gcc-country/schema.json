{
  "kind": "collectionType",
  "collectionName": "gcc_countries",
  "info": {
    "singularName": "gcc-country",
    "pluralName": "gcc-countries",
    "displayName": "GCC Country"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "summary": {
      "type": "text"
    },
    "flagImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "order": {
      "type": "integer"
    },
    "seo": {
      "type": "component",
      "component": "seo.entry",
      "repeatable": false
    }
  }
}
