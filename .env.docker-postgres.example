# Use with: docker compose --profile postgres up --build
# Copy values into .env (or merge with your secrets).

DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://strapi:strapi@postgres:5432/strapi

# Must match docker-compose postgres service:
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_NAME=strapi

HOST=0.0.0.0
PORT=1337

# Generate real secrets before production
APP_KEYS=keyA,keyB,keyC,keyD
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me
