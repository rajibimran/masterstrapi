# Server
HOST=0.0.0.0
PORT=1337

# Secrets (generate new values per environment — do not copy across production servers)
APP_KEYS=keyA,keyB,keyC,keyD
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me

# Database — default SQLite; set DATABASE_CLIENT=postgres to use PostgreSQL
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# --- PostgreSQL (optional: set DATABASE_CLIENT=postgres) ---
# DATABASE_CLIENT=postgres
# Option A — single URL:
# DATABASE_URL=postgresql://strapi:strapi@localhost:5432/strapi
# Option B — discrete fields (leave DATABASE_URL unset or empty):
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=strapi
# DATABASE_USERNAME=strapi
# DATABASE_PASSWORD=strapi
# DATABASE_SCHEMA=public
# DATABASE_SSL=false

# Optional: baseline restore path (used by scripts/restore-db.sh; Postgres only)
# BASELINE_DUMP_PATH=/secure/path/baseline.dump
